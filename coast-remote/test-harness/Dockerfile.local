FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-server bash \
    && rm -rf /var/lib/apt/lists/*

# Create a test user
RUN useradd -m -s /bin/bash testuser \
    && echo "testuser:testpass" | chpasswd

# Setup SSH server
RUN mkdir -p /run/sshd
RUN mkdir -p /home/testuser/.ssh && chown testuser:testuser /home/testuser/.ssh

# Create sample project files
RUN mkdir -p /home/testuser/project \
    && echo '{"name": "test-app", "version": "1.0.0"}' > /home/testuser/project/package.json \
    && echo 'console.log("hello from coast remote POC")' > /home/testuser/project/index.js \
    && echo 'version: "3"\nservices:\n  web:\n    image: nginx' > /home/testuser/project/docker-compose.yml \
    && echo 'FROM node:20-alpine\nCOPY . /app\nCMD ["node", "/app/index.js"]' > /home/testuser/project/Dockerfile \
    && chown -R testuser:testuser /home/testuser/project

# Allow SSH key auth and password auth (for test simplicity)
RUN sed -i 's/#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/#PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config

COPY entrypoint-local.sh /entrypoint-local.sh
RUN chmod +x /entrypoint-local.sh

EXPOSE 22

ENTRYPOINT ["/entrypoint-local.sh"]
